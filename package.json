{
  "name": "pennywatch",
  "version": "1.0.0",
  "description": "Personal finance tracker that reads bank SMS, parses with AI, and gives spending insights via Telegram",
  "main": "src/index.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "migrate": "tsx src/db/migrate.ts"
  },
  "keywords": ["finance", "sms", "telegram", "ai", "budgeting"],
  "author": "Derrick Tsorme",
  "license": "MIT",
  "type": "commonjs",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.86.1",
    "express": "^5.2.1",
    "node-cron": "^4.2.1",
    "pg": "^8.20.0",
    "telegraf": "^4.16.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.2",
    "@types/pg": "^8.20.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^3.2.4"
  }
}
